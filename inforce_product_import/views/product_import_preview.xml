<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="import_preview">
        <p><b><t t-out="summary"/></b></p>
        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr>
                    <th>SKU</th>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="rows" t-as="row">
                    <tr>
                        <td><t t-out="row['sku']"/></td>
                        <td><t t-out="row['name']"/></td>
                        <td><t t-out="row['brand']"/></td>
                        <td><t t-out="row['price']"/></td>
                        <td t-attf-style="color: {{ row['color'] }}; font-weight: bold;">
                            <t t-out="row['status']"/>
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>
        <p t-if="extra_count">
            <i>... and <t t-out="extra_count"/> more rows not shown.</i>
        </p>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_import_log_view_list" model="ir.ui.view">
        <field name="name">product.import.log.list</field>
        <field name="model">product.import.log</field>
        <field name="arch" type="xml">
            <list string="Import History" create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="file_name"/>
                <field name="created"/>
                <field name="updated"/>
                <field name="skipped"/>
                <field name="price_warnings"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'success'"
                       decoration-warning="state == 'warning'"/>
            </list>
        </field>
    </record>

    <record id="action_product_import_log" model="ir.actions.act_window">
        <field name="name">Import History</field>
        <field name="res_model">product.import.log</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem
        id="menu_product_import_log"
        name="Import History"
        parent="stock.menu_stock_inventory_control"
        action="action_product_import_log"
        sequence="101"/>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_import_wizard_view_form" model="ir.ui.view">
        <field name="name">product.import.wizard.form</field>
        <field name="model">product.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Products from XLSX">
                <field name="state" invisible="1"/>

                <!-- Step 1: upload -->
                <group invisible="state != 'upload'">
                    <field name="file_data" filename="file_name" widget="binary"
                           string="XLSX File" required="state == 'upload'"/>
                    <field name="file_name" invisible="1"/>
                </group>

                <!-- Step 2: preview table -->
                <div invisible="state != 'preview'">
                    <field name="preview_html" widget="html"/>
                </div>

                <footer>
                    <button name="action_preview" string="Preview" type="object"
                            class="btn-primary" invisible="state != 'upload'"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state != 'preview'"/>
                    <button name="action_back" string="Back" type="object"
                            class="btn-secondary" invisible="state != 'preview'"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Products from XLSX</field>
        <field name="res_model">product.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_product_import_wizard"
        name="Import from XLSX"
        parent="stock.menu_stock_inventory_control"
        action="action_product_import_wizard"
        sequence="100"/>

</odoo>
